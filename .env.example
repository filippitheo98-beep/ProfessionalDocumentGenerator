# Configuration de la base de données PostgreSQL
# Remplacez VOTRE_MOT_DE_PASSE par votre mot de passe PostgreSQL
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/duerp_app

# Environnement de production
NODE_ENV=production

# Clé secrète pour les sessions (générez une chaîne aléatoire longue)
SESSION_SECRET=votre-cle-secrete-tres-longue-et-aleatoire-changez-moi

# Compte administrateur : identifiant "admin", mot de passe par défaut "admin"
# Créé automatiquement au démarrage si inexistant. Première connexion oblige au changement de mot de passe.
# Optionnel : mot de passe initial si différent de "admin"
# ADMIN_INITIAL_PASSWORD=votre-mot-de-passe-initial

# IA (Ollama self-hosted)
# URL de votre serveur Ollama (sans /v1). Exemple : http://54.38.26.215:11434
# OLLAMA_BASE_URL=http://54.38.26.215:11434
#
# Modèle Ollama à utiliser. Exemple : llama3.2
# OLLAMA_MODEL=llama3.2

# Anthropic (Claude) - optionnel
# ANTHROPIC_API_KEY=sk-ant-votre-cle-anthropic