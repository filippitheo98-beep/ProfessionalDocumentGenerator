# Base de données PostgreSQL
DATABASE_URL=postgresql://duerp_user:votre_mot_de_passe@localhost:5000/duerp_db

# Clé API OpenAI (pour l'analyse IA des risques)
OPENAI_API_KEY=votre_cle_openai_ici

# Port de l'application (optionnel, par défaut 5000)
# Pour éviter les conflits avec PostgreSQL local sur port 5000, utilisez 3000
PORT=3000

# Variables PostgreSQL (si vous utilisez Docker)
POSTGRES_DB=duerp_db
POSTGRES_USER=duerp_user
POSTGRES_PASSWORD=votre_mot_de_passe